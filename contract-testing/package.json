{
  "name": "api-contract-testing",
  "version": "1.0.0",
  "description": "API Contract Testing Suite for StrellerMinds Backend",
  "scripts": {
    "test:contract": "jest --config contract-test.config.js",
    "test:contract:watch": "jest --config contract-test.config.js --watch",
