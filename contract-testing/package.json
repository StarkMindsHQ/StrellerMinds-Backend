    "axios": "^1.13.2",
    "chai": "^5.1.2",
    "chai-http": "^5.1.1",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "json-schema-diff": "^0.19.0",
    "openapi-schema-validator": "^12.1.3",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.6"
