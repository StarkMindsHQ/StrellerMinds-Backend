# Database Sharding Configuration
# Copy this file to .env and fill in your actual shard configurations

# Number of database shards
DATABASE_SHARD_COUNT=4

# Shard 0 Configuration (Primary)
DATABASE_SHARD_0_HOST=localhost
DATABASE_SHARD_0_PORT=5432
DATABASE_SHARD_0_NAME=strellerminds_shard_0
DATABASE_SHARD_0_USER=your_shard_user_0
DATABASE_SHARD_0_PASSWORD=your_shard_password_0

# Shard 1 Configuration
DATABASE_SHARD_1_HOST=localhost
DATABASE_SHARD_1_PORT=5433
DATABASE_SHARD_1_NAME=strellerminds_shard_1
DATABASE_SHARD_1_USER=your_shard_user_1
DATABASE_SHARD_1_PASSWORD=your_shard_password_1

# Shard 2 Configuration
DATABASE_SHARD_2_HOST=localhost
DATABASE_SHARD_2_PORT=5434
DATABASE_SHARD_2_NAME=strellerminds_shard_2
DATABASE_SHARD_2_USER=your_shard_user_2
DATABASE_SHARD_2_PASSWORD=your_shard_password_2

# Shard 3 Configuration
DATABASE_SHARD_3_HOST=localhost
DATABASE_SHARD_3_PORT=5435
DATABASE_SHARD_3_NAME=strellerminds_shard_3
DATABASE_SHARD_3_USER=your_shard_user_3
DATABASE_SHARD_3_PASSWORD=your_shard_password_3

# Sharding Strategy Configuration
# Available strategies: user, course, shared
DEFAULT_SHARDING_STRATEGY=user

# Connection Pool Settings per Shard
DATABASE_POOL_MAX=10
DATABASE_POOL_MIN=1
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=10000
DATABASE_ACQUIRE_TIMEOUT=60000
DATABASE_CREATE_TIMEOUT=30000
DATABASE_DESTROY_TIMEOUT=5000
DATABASE_REAP_INTERVAL=1000
DATABASE_CREATE_RETRY_INTERVAL=200

# Sharding Health Check Configuration
SHARD_HEALTH_CHECK_INTERVAL=30000
SHARD_HEALTH_CHECK_TIMEOUT=5000
SHARD_AUTO_RECONNECT_ENABLED=true
SHARD_MAX_RETRY_ATTEMPTS=3

# Migration and Rebalancing Settings
SHARD_MIGRATION_BATCH_SIZE=100
SHARD_REBALANCING_ENABLED=false
SHARD_REBALANCING_THRESHOLD=0.8

# Monitoring and Metrics
SHARD_METRICS_ENABLED=true
SHARD_QUERY_LOGGING_ENABLED=false
SHARD_PERFORMANCE_MONITORING=true
